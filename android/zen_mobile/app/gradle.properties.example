# Android Release Signing Configuration
# 签名文件路径：~/.android/release.keystore
# 如需创建新签名：keytool -genkey -v -keystore ~/.android/release.keystore -keyalg RSA -keysize 2048 -validity 10000 -alias release
#
# 密码请通过环境变量设置，勿在此文件中填写：
#   ZEN_ANDROID_STORE_FILE=/path/to/release.keystore
#   ZEN_ANDROID_STORE_PASSWORD=your_release_store_password
#   ZEN_ANDROID_KEY_ALIAS=release
#   ZEN_ANDROID_KEY_PASSWORD=your_release_key_password
